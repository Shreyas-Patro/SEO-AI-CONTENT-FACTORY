# NEVER commit config.yaml — it's in .gitignore.

anthropic:
  api_key: "sk-ant-REPLACE-WITH-YOUR-KEY"
  models:
    writer: "claude-sonnet-4-20250514"
    architect: "claude-sonnet-4-20250514"
    bulk: "claude-haiku-4-5-20251001"
  max_retries: 3
  retry_delay_seconds: 5

serpapi:
  api_key: "REPLACE-WITH-YOUR-SERPAPI-KEY"
  monthly_budget_searches: 5000
  cache_ttl_days: 7

site:
  base_url: "https://canvas-homes.com"
  brand_name: "Canvas Homes"

paths:
  database: "data/canvas.db"
  chroma_dir: "data/chroma"
  graph_file: "data/graph.graphml"
  research_dir: "research_docs"
  outputs_dir: "outputs"
  prompts_dir: "prompts"
  logs_dir: "logs"
  cache_dir: "data/cache"

pipeline:
  max_concurrent_clusters: 2
  article_token_budget: 20000
  polling_interval_seconds: 5

quality:
  min_readability_score: 55
  min_brand_tone_score: 6.5
  min_fact_check_confidence: 0.85
  max_passive_voice_pct: 12
  target_flesch_kincaid: 65

competitors:
  - "magicbricks.com"
  - "nobroker.in"
  - "housing.com"
  - "99acres.com"